APP_LOG_LEVEL=INFO

SEIZURE_MODEL_NAME=RawWindow CNN-SeqBiGRU Preictal Risk Estimator
SEIZURE_MODEL_VERSION=raw-window-cnn-seqbigru-v1
SEIZURE_MODEL_CHECKPOINT=models/checkpoints/seizure_prediction_model.pt
SEIZURE_MODEL_CHECKPOINTS=models/checkpoints/model-1.pt,models/checkpoints/model-2.pt,models/checkpoints/model-3.pt,models/checkpoints/model-4.pt
SEIZURE_MODEL_DEVICE=cpu
SEIZURE_STRICT_CHECKPOINT_LOADING=true

SEIZURE_REQUIRED_CHANNELS=Fp1,Fp2,F7,F3,Fz,F4,F8,T3,C3,Cz,C4,T4,T5,P3,Pz,P4,T6,O1
SEIZURE_MINIMUM_MAPPED_CHANNELS=14
SEIZURE_MAX_ZERO_FILL_CHANNELS=4
SEIZURE_MIN_RECORDING_DURATION_SECONDS=30
SEIZURE_TARGET_SAMPLE_RATE_HZ=256

SEIZURE_WINDOW_LENGTH_SECONDS=5.0
SEIZURE_OVERLAP_SECONDS=2.5
SEIZURE_EXPECTED_WINDOW_SIZE=1280
SEIZURE_SEQUENCE_LENGTH=8
SEIZURE_INFERENCE_BATCH_SIZE=16
SEIZURE_DEFAULT_THRESHOLD=0.45
SEIZURE_SMOOTHING_METHOD=ema
SEIZURE_SMOOTHING_ALPHA=0.35
SEIZURE_SMOOTHING_WINDOW=3
SEIZURE_CONSECUTIVE_SEGMENTS_REQUIRED=3

SEIZURE_MAX_UPLOAD_SIZE_MB=2048
